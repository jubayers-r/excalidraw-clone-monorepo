{
  "name": "http-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./src/index.ts",
    "build": "tsc -b",
    "start": "node ./dist/index.js"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@repo/backend-common": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.0.0"
  },
  "turbo": {
    "tasks": {
      "build": {
        "inputs": ["$TURBO_DEFAULT$", ".env.production"]
      }
    }
  }
}